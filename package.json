{
  "name": "blog",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:admin": "cd admin && npm run dev",
    "build": "cd admin && npm run build",
    "build:deploy": "bash scripts/build.sh",
    "deploy": "bash scripts/build.sh && source .env && CF_API_TOKEN=$CF_API_TOKEN npx wrangler deploy --env production",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply blog-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply blog-db-prod --remote --env production",
    "d1:create": "wrangler d1 create blog-db-prod",
    "r2:create": "wrangler r2 bucket create blog-images",
    "secret:set": "wrangler secret put --env production",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.12.9",
    "katex": "^0.16.44",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.5",
    "@cloudflare/workers-types": "^4.20260329.1",
    "@types/katex": "^0.16.8",
    "drizzle-kit": "^0.30.6",
    "esbuild": "^0.27.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "wrangler": "^4.78.0"
  }
}
